---
import "../../styles/myspace.css";
---

<section id="about" class="retro-profile-section">
  <header class="profile-header-bar">
    <div class="header-content-wrap">
      <div class="site-branding">
        Davespace <span class="tagline">a space for development</span>
      </div>
      <div class="profile-search">
        Find Devs: <input type="text" />
        <button>Go</button>
      </div>
      <div class="utility-links">Settings | Sign Out</div>
    </div>
  </header>

  <div class="profile-nav-bar">
    <a href="#">Home</a> |
    <a href="#">Browse</a> |
    <a href="#">Search</a> |
    <a href="#">Messages</a> |
    <a href="#">Bulletins</a> |
    <a href="#">Forums</a> |
    <a href="#">Groups</a> |
    <a href="#">Layouts</a> |
    <a href="#">Favorites</a> |
    <a href="#">Invite</a> |
    <a href="#">App</a> |
    <a href="#">Shop</a> |
    <a href="#">About</a>
  </div>

  <div class="profile-layout-grid">
    <div class="profile-sidebar">
      <h1>David Norman</h1>
      <div class="profile-edit-actions">
        [customise profile] [update avatar]
      </div>

      <div class="avatar-status-wrap">
        <div class="profile-avatar">
          <img src="/images/profiles/profile-alt.jpg" alt="David Norman" />
        </div>
        <div class="user-status-badge">
          ACTIVE NOW <br /><span class="edit-action">[change status]</span>
        </div>
      </div>

      <p class="current-mood">
        <b>Current Status:</b> 🎨 Building cool stuff [update]
      </p>
      <p class="quick-nav-links">
        Quick links: <span>Posts</span> | <span>Updates</span>
      </p>

      <div class="sidebar-section">
        <h3>Connect With David</h3>
        <table class="action-links-table">
          <tr><td>🤝 Add to Network</td><td>⭐ Bookmark Profile</td></tr>
          <tr><td>📧 Send Email</td><td>🔗 Share Profile</td></tr>
          <tr><td>💬 Start Chat</td><td>🔕 Mute Updates</td></tr>
        </table>
      </div>

      <div class="sidebar-section">
        <h3>David's Interests</h3>
        <table class="info-details-table">
          <tr>
            <td class="detail-label">General</td>
            <td
              >Building elegant UIs, exploring new web technologies, sharing
              knowledge through blog posts, coffee ☕</td
            >
          </tr>
          <tr>
            <td class="detail-label">Music</td>
            <td>Lo-fi beats while coding, synthwave, indie electronic</td>
          </tr>
          <tr>
            <td class="detail-label">Entertainment</td>
            <td>Sci-fi, tech documentaries, indie films</td>
          </tr>
          <tr>
            <td class="detail-label">Tech Stack</td>
            <td>React, TypeScript, Astro, CSS/Sass, Design Systems, Figma</td>
          </tr>
        </table>
        <div class="inline-edit-link">[customise]</div>
      </div>
    </div>

    <div class="profile-main-content">
      <div class="profile-cta-banner">Customise Your Profile</div>

      <div class="updates-section">
        <p><b>David's Recent Posts</b> [View Archive]</p>
        <p class="empty-state-text">No posts yet. Check back soon!</p>
      </div>

      <div class="content-section-header">About David</div>
      <div class="subsection-title">Bio:</div>
      <div class="text-content-area">
        <p>
          Senior Front End Developer & UX Designer passionate about creating
          beautiful web experiences. I love connecting with people who are
          curious about technology and always learning.
        </p>
        <p>
          <b>Based in:</b> The Internet<br />
          <b>Role:</b> Senior Front End Developer & UX Designer<br />
          <b>Availability:</b> Open to interesting projects and collaborations
        </p>
        <p>[customise bio]</p>
      </div>

      <div class="content-section-header">
        <span>David's Network</span>
        <span class="view-more">[view network]</span>
      </div>
      <p class="connection-count-text">Connected with <b>2</b> developers.</p>
      <div class="connections-grid">
        <div class="connection-card">
          <div
            class="connection-avatar"
            style="background:#0d47a1; color:white;"
          >
            AB
          </div>
          Andy B
        </div>
        <div class="connection-card">
          <div class="connection-avatar">MG</div>
          Mark G
        </div>
      </div>
    </div>
  </div>
</section>
