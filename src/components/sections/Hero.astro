---
import { Image } from "astro:assets";
import WaveBackground from "../ui/WaveBackground.astro";
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="hero-greeting">David Norman</span>
        <span class="hero-subtitle"
          >Front End Developer & <br /> UX Designer & <br /> Tired Dad</span
        >
      </h1>
      <div class="hero-cta"></div>
    </div>

    <div class="hero-image">
      <Image
        src="/images/profiles/bust.png"
        alt="Hero illustration"
        width={100}
        height={100}
      />
    </div>
  </div>
  <WaveBackground />
</section>

<style>
  .hero {
    --button-hover: color-mix(in srgb, var(--color-hero-bg), black 10%);
    background-color: var(--color-hero-bg);
    background-image: url("/images/backgrounds/hero-background.svg");
    background-attachment: scroll;
    background-size: cover;
    background-position: center;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: var(--space-lg) var(--space-md);
    scroll-snap-align: start;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    max-width: 1200px;
    width: 100%;
    z-index: 10;
  }

  .hero-content {
    flex: 1;
    text-align: left;
  }

  .hero-image {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image img {
    width: 100%;
    max-width: 500px;
    height: auto;
  }

  .hero-title,
  .hero-title span {
    font-family: "Ubuntu", sans-serif;
    font-weight: 700;
  }

  .hero-description {
    font-family: "Open Sans", sans-serif;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    line-height: 1;
  }

  .hero-pre-greeting {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 300;
    letter-spacing: 0.5px;
    color: var(--color-text);
    text-shadow: 0px 1px 1px #f19fb5;
    text-align: left;
    position: relative;
    left: 4px;
  }

  .hero-greeting {
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 900;
    font-family: "Archivo Black", sans-serif;
    color: var(--color-text);
    text-shadow: 0px 1px 1px #f19fb5;
  }

  .hero-subtitle {
    font-size: clamp(1.5rem, 3vw, 1.8rem);
    font-weight: 300;
    color: var(--color-text-on-dark);
    letter-spacing: 0.5px;
    text-shadow: 0px 1px 1px rgba(0, 0, 0, 0.3);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-greeting {
      animation: none;
      background-position: 0% 50%;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100svh;
    }

    .hero-inner {
      flex-direction: column;
      text-align: center;
    }

    .hero-content {
      text-align: center;
    }

    .hero-cta {
      justify-content: center;
    }

    .hero-image {
      order: -1;
    }

    .hero-image img {
      max-width: 300px;
    }
  }
</style>

<script>
  document.getElementById("about-cta")?.addEventListener("click", (e) => {
    e.preventDefault();
    document.getElementById("about")?.scrollIntoView({ behavior: "smooth" });
    window.history.pushState(null, "", "#about");
  });
</script>
