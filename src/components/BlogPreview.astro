---
import "../styles/blog-preview.css";
import { getCollection } from "astro:content";

// Get all blog posts and sort by date (newest first)
const allPosts = await getCollection("posts");
const blogPosts = allPosts
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 2); // Get the latest 2 posts
---

<section id="blog" class="blog-preview-section">
  <div class="blog-preview-container">
    <div class="blog-preview-header">
      <h2>Latest Posts</h2>
      <p>Thoughts on web development, design, and everything in between</p>
    </div>

    <div class="blog-posts-grid">
      {
        blogPosts.map((post) => (
          <article class="blog-post-card">
            <div class="blog-post-date">
              {new Date(post.data.date).toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              })}
            </div>
            <h3>{post.data.title}</h3>
            <p class="blog-post-excerpt">{post.data.description}</p>
            <a href={`/posts/${post.slug}`} class="blog-read-more">
              Read More
            </a>
          </article>
        ))
      }
    </div>

    <div class="blog-view-all">
      <a href="/posts" class="btn btn-secondary btn-white">View All Posts</a>
    </div>
  </div>
</section>
