---
import "../styles/blog-preview.css";
import { getCollection } from "astro:content";

// Get all blog posts and sort by date (newest first)
const allPosts = await getCollection("posts");
const blogPosts = allPosts
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 2); // Get the latest 2 posts
---

<section id="blog" class="blog-preview-section">
  <div class="blog-preview-container">
    <div class="blog-preview-header">
      <h2>Musings</h2>
      <p>Things I managed to focus on long enough to write about.</p>
      <p>Could be waffle, could be useful, who knows?</p>
    </div>

    <div class="blog-posts-grid">
      {
        blogPosts.map((post) => (
          <a href={`/posts/${post.slug}`} class="blog-post-card pressable">
            <div
              class="blog-post-date"
              transition:name={`post-date-${post.slug}`}
            >
              {new Date(post.data.date).toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              })}
            </div>
            <h3 transition:name={`post-title-${post.slug}`}>
              {post.data.title}
            </h3>
            <p
              class="blog-post-excerpt"
              transition:name={`post-desc-${post.slug}`}
            >
              {post.data.description}
            </p>
            <span class="blog-read-more">Read More</span>
          </a>
        ))
      }
    </div>

    <div class="blog-view-all">
      <a href="/posts" class="btn btn-secondary pressable">View All Posts</a>
    </div>
  </div>
</section>
