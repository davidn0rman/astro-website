---
// Hero Section Component
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">
      <span class="hero-greeting">Hey, I'm David Norman</span>
      <span class="hero-subtitle">Senior Front End Developer & UX Designer</span
      >
    </h1>
    <p class="hero-description">
      I build beautiful, functional web experiences and share what I learn along
      the way.
    </p>
    <div class="hero-cta">
      <a href="#projects" class="cta-button primary">View My Work</a>
      <a href="#about" class="cta-button secondary">About Me</a>
    </div>
  </div>
  <div class="hero-decoration">
    <div class="floating-element element-1"></div>
    <div class="floating-element element-2"></div>
    <div class="floating-element element-3"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
    padding: var(--space-lg) var(--space-md);
    scroll-snap-align: start;
  }

  .hero-content {
    max-width: 800px;
    z-index: 10;
    text-align: center;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .hero-greeting {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    background: linear-gradient(135deg, #00d9ff 0%, #7b2cbf 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 8s ease infinite;
    background-size: 200% 200%;
  }

  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .hero-subtitle {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 300;
    color: #a8a8a8;
    letter-spacing: 0.5px;
  }

  .hero-description {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: #c8c8c8;
    margin-bottom: var(--space-lg);
    line-height: 1.8;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border: 2px solid transparent;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .cta-button.primary {
    background: linear-gradient(135deg, #00d9ff 0%, #7b2cbf 100%);
    background-origin: border-box;
    color: #ffffff;
    box-shadow: 0 8px 24px rgba(0, 217, 255, 0.3);
  }

  .cta-button.primary:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 217, 255, 0.5);
  }

  .cta-button.secondary {
    background: transparent;
    color: #00d9ff;
    border-color: #00d9ff;
  }

  .cta-button.secondary:hover {
    background: rgba(0, 217, 255, 0.1);
    transform: translateY(-4px);
  }

  .hero-decoration {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .floating-element {
    position: absolute;
    border-radius: 50%;
    opacity: 0.15;
    animation: float 20s ease-in-out infinite;
  }

  .element-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #00d9ff 0%, transparent 70%);
    top: 10%;
    left: -10%;
    animation-delay: 0s;
  }

  .element-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #7b2cbf 0%, transparent 70%);
    bottom: -10%;
    right: -10%;
    animation-delay: 7s;
  }

  .element-3 {
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, #ff006e 0%, transparent 70%);
    top: 50%;
    right: 10%;
    animation-delay: 14s;
  }

  @keyframes float {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(50px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-30px, 30px) scale(0.9);
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
    }

    .hero-cta {
      flex-direction: column;
      align-items: center;
    }

    .cta-button {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
