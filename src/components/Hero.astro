---
// Hero Section Component
import FloatingDecoration from "./FloatingDecoration.astro";
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">
      <span class="hero-greeting">Hey, I'm David Norman</span>
      <span class="hero-subtitle"
        >Senior Front End Developer, UX Designer & Tired Dad</span
      >
    </h1>
    <p class="hero-description">
      This site is not yet finished, so please mind the mess
    </p>
    <div class="hero-cta">
      <a id="about-cta" href="#about" class="btn btn-primary pressable"
        >About Me</a
      >
      <!-- <a href="#projects" class="btn btn-rainbow pressable">Test</a> -->
    </div>
  </div>
  <FloatingDecoration />
</section>

<style>
  .hero {
    --button-hover: hsl(from #191a2e h s calc(l + 10));
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
    padding: var(--space-lg) var(--space-sm);
    scroll-snap-align: start;
  }

  .hero-title,
  .hero-title span {
    font-family: "Ubuntu", sans-serif;
    font-weight: 700;
  }

  .hero-description {
    font-family: "Open Sans", sans-serif;
  }

  .hero-content {
    max-width: 800px;
    z-index: 10;
    text-align: center;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .hero-greeting {
    font-size: clamp(3rem, 5vw, 4rem);
    font-weight: 900;
    background: linear-gradient(135deg, #00d9ff 0%, #7b2cbf 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 8s ease infinite;
    background-size: 200% 200%;
  }

  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-greeting {
      animation: none;
      background-position: 0% 50%;
    }
  }

  .hero-subtitle {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 300;
    color: #a8a8a8;
    letter-spacing: 0.5px;
  }

  .hero-description {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: #c8c8c8;
    margin-bottom: var(--space-lg);
    line-height: 1.8;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
    }

    .hero-cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<script>
  document.getElementById("about-cta")?.addEventListener("click", (e) => {
    e.preventDefault();
    document.getElementById("about")?.scrollIntoView({ behavior: "smooth" });
    window.history.pushState(null, "", "#about");
  });
</script>
