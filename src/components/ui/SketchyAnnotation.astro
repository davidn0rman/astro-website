const svgs = {
    about: {
        viewBox: "0 0 205 120",
        width: 205,
        height: 120,
        paths: aboutMePaths,
    },
    thatsMe: {
        viewBox: "0 0 205 120",
        width: 205,
        height: 120,
        paths: thatsMePaths,
