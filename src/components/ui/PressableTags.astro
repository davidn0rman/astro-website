---
interface Props {
    tags: string[];
}

const { tags } = Astro.props;
---

<div class="sidebar-tags">
    {
        tags.map((tag) => (
            <a href={`/tags/${tag}`} class="btn pressable sidebar-tag">
                {tag}
            </a>
        ))
    }
</div>

<style>
    .sidebar-tags {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-xs);
    }

    .sidebar-tag {
        color: var(--color-text-light);
        padding: 0.35rem 0.85rem;
        font-size: 0.75rem;
        text-transform: none;
        letter-spacing: normal;
        border-radius: 16px;
        border-width: 1px;
        font-weight: 600;
        --button-hover: color-mix(
            in srgb,
            var(--color-social-bg-end),
            black 10%
        );
    }

    /* This overrides the default pressable styles */
    .pressable {
        box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.2);
    }

    .pressable:hover {
        top: 3px;
        left: 3px;
        box-shadow: none;
    }
</style>
