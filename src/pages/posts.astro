---
import Footer from "../components/Footer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<BaseLayout title="Blog Posts">
    <section
        style="padding: var(--space-xl) var(--space-md); background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);"
    >
        <div style="max-width: 800px; margin: 0 auto;">
            <h1
                style="font-size: 3rem; color: #ffffff; margin-bottom: var(--space-md); text-align: center;"
            >
                All Posts
            </h1>

            <div
                style="display: flex; flex-direction: column; gap: var(--space-md);"
            >
                {
                    sortedPosts.map((post) => (
                        <article style="background: rgba(255, 255, 255, 0.05); padding: var(--space-md); border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1);">
                            <div style="font-size: 0.875rem; color: #00d9ff; margin-bottom: var(--space-xs);">
                                {new Date(post.data.date).toLocaleDateString(
                                    "en-GB",
                                    {
                                        month: "long",
                                        day: "numeric",
                                        year: "numeric",
                                    },
                                )}
                            </div>
                            <h2 style="font-size: 1.5rem; margin-bottom: var(--space-sm);">
                                <a
                                    href={`/posts/${post.slug}`}
                                    style="color: #ffffff; text-decoration: none; transition: color 0.3s;"
                                >
                                    {post.data.title}
                                </a>
                            </h2>
                            <p style="color: #c8c8c8; margin-bottom: var(--space-sm);">
                                {post.data.description}
                            </p>
                            <div style="display: flex; gap: var(--space-xs); flex-wrap: wrap;">
                                {post.data.tags?.map((tag) => (
                                    <span style="background: rgba(0, 217, 255, 0.2); color: #00d9ff; padding: 0.25rem 0.75rem; border-radius: 12px; font-size: 0.75rem;">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </article>
                    ))
                }
            </div>

            <div style="text-align: center; margin-top: var(--space-lg);">
                <a href="/" class="btn btn-secondary">Back to Home</a>
            </div>
        </div>
    </section>
    <Footer />
</BaseLayout>
