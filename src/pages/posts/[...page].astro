---
import { getCollection, type CollectionEntry } from "astro:content";
import type { GetStaticPaths, Page } from "astro";
import Footer from "../../components/sections/Footer.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SocialLinks from "../../components/sections/SocialLinks.astro";
import PostPageCard from "../../components/ui/PostPageCard.astro";
import PaginationButton from "../../components/ui/PaginationButton.astro";
import PressableTags from "../../components/ui/PressableTags.astro";

export const getStaticPaths = (async ({ paginate }) => {
    const allPosts = await getCollection("posts");
    const sortedPosts = allPosts.sort(
        (a, b) =>
            new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    );
    const POSTS_PER_PAGE = 4;
    return paginate(sortedPosts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

interface Props {
    page: Page<CollectionEntry<"posts">>;
}

const { page } = Astro.props;

// Get all tags for the sidebar
const allPostsForTags = await getCollection("posts");
const uniqueTags = [
    ...new Set(allPostsForTags.flatMap((post) => post.data.tags || [])),
].sort();
---

<BaseLayout title="All Posts">
    <section class="posts-section">
        <div class="posts-container">
            <div class="posts-header">
                <a
                    href="/#blog"
                    class="back-icon pressable"
                    aria-label="Back to Home"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                </a>
                <h1 class="posts-title">All Posts</h1>
            </div>

            <div class="layout-with-sidebar">
                <div class="posts-main">
                    <div class="posts-list">
                        {page.data.map((post) => <PostPageCard post={post} />)}
                    </div>

                    <nav class="pagination" aria-label="Pagination">
                        <div class="pagination-prev">
                            <PaginationButton
                                href={page.url.prev}
                                direction="prev"
                            />
                        </div>
                        <div class="pagination-info">
                            Page {page.currentPage} of {page.lastPage}
                        </div>
                        <div class="pagination-next">
                            <PaginationButton
                                href={page.url.next}
                                direction="next"
                            />
                        </div>
                    </nav>
                </div>

                <aside class="tags-sidebar">
                    <h3 class="sidebar-title">Topics</h3>
                    <PressableTags tags={uniqueTags} />
                </aside>
            </div>
        </div>
    </section>
    <SocialLinks />
    <Footer />
</BaseLayout>

<style>
    .posts-section {
        padding: var(--space-xl) var(--space-sm);
        background: color-mix(in srgb, var(--color-social-bg-end), black 10%);
    }

    .layout-with-sidebar {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: var(--space-lg);
        align-items: start;
    }

    .tags-sidebar {
        background: var(--color-social-bg-end);
        padding: var(--space-md);
        border-radius: 8px;
        position: sticky;
        top: var(--space-xl);
        border: 1px solid var(--color-border);
        margin-bottom: 126px;
    }

    .sidebar-title {
        font-size: 1.2rem;
        margin-bottom: var(--space-md);
        color: var(--color-text-light);
        font-weight: 700;
    }

    .posts-container {
        max-width: 1000px; /* Widened slightly to accommodate sidebar comfortably */
        margin: 0 auto;
    }

    .posts-header {
        position: relative;
        display: flex;
        align-items: center;
        gap: var(--space-md);
        margin-bottom: var(--space-lg);
    }

    .posts-title {
        font-size: 3rem;
        color: var(--color-text-light);
        margin: 0;
        flex: 1 0 auto;
        text-align: center;
    }

    /* Back icon — matches social link icon style */
    .back-icon {
        position: absolute;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-border-subtle);
        border-radius: 50%;
        color: var(--color-text-muted);
        border: 2px solid currentColor;
        text-decoration: none;
        z-index: 0;
        flex-shrink: 0;
    }

    .back-icon::before {
        content: "";
        position: absolute;
        inset: -2px;
        border-radius: 50%;
        background: linear-gradient(
            var(--rotate),
            #e40303 0%,
            #ff8c00 16%,
            #ffed00 33%,
            #008026 50%,
            #004dff 66%,
            #750787 83%
        );
        z-index: -2;
        opacity: 0;
        animation: rotate-gradient 4s linear infinite;
        animation-play-state: paused;
    }

    .back-icon::after {
        content: "";
        position: absolute;
        inset: 0px;
        border-radius: 50%;
        background-color: var(--color-social-bg-start);
        z-index: -1;
        opacity: 0;
    }

    .back-icon:hover {
        color: var(--color-text-on-dark);
        border-color: transparent;
        transform: rotate(5deg);
    }

    .back-icon:hover::before {
        opacity: 1;
        animation-play-state: running;
    }

    .back-icon:hover::after {
        opacity: 1;
    }

    .posts-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .pagination {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: var(--space-md);
        margin-top: var(--space-lg);
    }

    .pagination-prev {
        justify-self: start;
    }

    .pagination-next {
        justify-self: end;
    }

    .pagination-info {
        color: var(--color-text-muted);
        font-weight: 600;
        font-size: 0.9rem;
        white-space: nowrap;
        text-align: center;
    }

    /* Stack on smaller screens */
    @media (max-width: 768px) {
        .layout-with-sidebar {
            grid-template-columns: 1fr;
        }

        .tags-sidebar {
            margin-bottom: 0;
        }
    }
</style>
