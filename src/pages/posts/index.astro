---
import { getCollection } from "astro:content";
import Footer from "../../components/Footer.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<BaseLayout title="Blog Posts">
    <section
        style="padding: var(--space-xl) var(--space-md); background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);"
    >
        <div style="max-width: 800px; margin: 0 auto;">
            <h1
                style="font-size: 3rem; color: #ffffff; margin-bottom: var(--space-md); text-align: center;"
            >
                All Posts
            </h1>

            <div
                style="display: flex; flex-direction: column; gap: var(--space-md);"
            >
                {
                    sortedPosts.map((post) => (
                        <article
                            style="background: rgba(255, 255, 255, 0.95); padding: var(--space-md); border-radius: 0; border: 4px solid #000000; box-shadow: 8px 8px 0 #000000; transition: transform 0.2s ease, box-shadow 0.2s ease; cursor: pointer;"
                            onmouseover="this.style.transform='translate(3px, 3px)'; this.style.boxShadow='5px 5px 0 #000000';"
                            onmouseout="this.style.transform=''; this.style.boxShadow='8px 8px 0 #000000';"
                        >
                            <div style="font-size: 0.875rem; color: #667eea; margin-bottom: var(--space-xs); font-weight: 600;">
                                {new Date(post.data.date).toLocaleDateString(
                                    "en-GB",
                                    {
                                        month: "long",
                                        day: "numeric",
                                        year: "numeric",
                                    },
                                )}
                            </div>
                            <h2 style="font-size: 1.5rem; margin-bottom: var(--space-sm);">
                                <a
                                    href={`/posts/${post.slug}`}
                                    style="color: #2d3748; text-decoration: none; transition: color 0.3s;"
                                >
                                    {post.data.title}
                                </a>
                            </h2>
                            <p style="color: #4a5568; margin-bottom: var(--space-sm);">
                                {post.data.description}
                            </p>
                            <div style="display: flex; gap: var(--space-xs); flex-wrap: wrap;">
                                {post.data.tags?.map((tag) => (
                                    <span style="background: rgba(102, 126, 234, 0.2); color: #667eea; padding: 0.25rem 0.75rem; border-radius: 0; font-size: 0.75rem; border: 2px solid #667eea;">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </article>
                    ))
                }
            </div>

            <div style="text-align: center; margin-top: var(--space-lg);">
                <a href="/" class="btn btn-secondary">Back to Home</a>
            </div>
        </div>
    </section>
    <Footer />
</BaseLayout>
